        div.addEventListener('click', (e) => {
          e.stopPropagation();
          if (highlightedSlots.size > 0) applyCategory(cat);
        });
        div.addEventListener('touchstart', (e) => { e.stopPropagation(); startLongPress(e, cat); }, { passive: false });
        div.addEventListener('touchend', (e) => { e.stopPropagation(); cancelLongPress(); });
        div.addEventListener('touchmove', cancelLongPress);
        div.addEventListener('mousedown', (e) => startLongPress(e, cat));
        div.addEventListener('mouseup', cancelLongPress);
