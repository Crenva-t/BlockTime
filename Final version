              const m = o.date.getMonth() + 1;
              const d = o.date.getDate();
              let displayHour = Math.floor(o.bedtimeHour);
              if (displayHour >= 24) displayHour -= 24;
              const min = Math.round((o.bedtimeHour - Math.floor(o.bedtimeHour)) * 60);
              const timeStr = `${String(displayHour).padStart(2, '0')}:${String(min).padStart(2, '0')}`;
              point4Content += `<span class="point-highlight">${m}月${d}日 ${timeStr}</span>（偏离约${Math.round(o.deviation * 60)}分钟）<br>`;
            });
            point4Content += `这种偶发性的熬夜可能会打乱您的睡眠节律，导致后续几天的入睡困难。建议尽量避免单次大幅度的作息变动，即使特殊情况也尽量不要偏离平时入睡时间超过1小时。`;
          } else {
            point4Content = `The following dates show bedtimes that <b>significantly deviated</b> from your average:<br>`;
            const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
            outliers.forEach(o => {
              let displayHour = Math.floor(o.bedtimeHour);
              if (displayHour >= 24) displayHour -= 24;
              const min = Math.round((o.bedtimeHour - Math.floor(o.bedtimeHour)) * 60);
              const timeStr = `${String(displayHour).padStart(2, '0')}:${String(min).padStart(2, '0')}`;
              point4Content += `<span class="point-highlight">${months[o.date.getMonth()]} ${o.date.getDate()} ${timeStr}</span> (~${Math.round(o.deviation * 60)} min deviation)<br>`;
            });
            point4Content += `Such occasional late nights can disrupt your sleep rhythm and make it harder to fall asleep in the following days. Try to avoid large single-day shifts in bedtime, and even in special circumstances, keep deviations within 1 hour of your usual bedtime.`;
          }
          htmlParts.push(`<div class="advice-point ${point4Class}"><span class="point-label">${t('advicePoint4Label')}</span>${point4Content}</div>`);
        }
      } else if (validBedtimeData.length === 1) {
        if (isZh) {
          htmlParts.push(`<div class="advice-point advice-encourage"><span class="point-label">${t('advicePoint3Label')}</span>目前只有1天的入睡时间数据，还无法分析稳定度。请继续记录更多天的睡眠数据后再查看。</div>`);
        } else {
          htmlParts.push(`<div class="advice-point advice-encourage"><span class="point-label">${t('advicePoint3Label')}</span>Only 1 day of bedtime data is available so far. Please record more sleep data for a stability analysis.</div>`);
        }
      }

      resultArea.innerHTML = htmlParts.join('');
      resultArea.classList.add('visible');
    }

