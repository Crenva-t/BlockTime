      const validBedtimeData = validSleepData.filter(d => d.bedtimeHour !== null);
      if (validBedtimeData.length > 0) {
        const avgBedtime = validBedtimeData.reduce((sum, d) => sum + d.bedtimeHour, 0) / validBedtimeData.length;
        let displayHour = Math.floor(avgBedtime);
        if (displayHour >= 24) displayHour -= 24;
        const displayMin = Math.round((avgBedtime - Math.floor(avgBedtime)) * 60);
        const avgBedtimeStr = `${String(displayHour).padStart(2, '0')}:${String(displayMin).padStart(2, '0')}`;
        const bedtimeValue = avgBedtime;
        let point2Class = 'advice-encourage';
        let point2Content = '';

        if (bedtimeValue < 23.5) {
          point2Class = 'advice-encourage';
          if (isZh) {
            point2Content = `您的平均入睡时间为 <span class="point-highlight">${avgBedtimeStr}</span>，<span class="point-good">作息良好</span>！保持规律的入睡时间有助于维持健康的昼夜节律，请继续保持！`;
