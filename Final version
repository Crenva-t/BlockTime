    function formatDate(date) {
      const y = date.getFullYear();
      const m = String(date.getMonth() + 1).padStart(2, '0');
      const d = String(date.getDate()).padStart(2, '0');
      return `${y}-${m}-${d}`;
    }

    function formatDateDisplay(date) {
      const y = date.getFullYear();
      const m = date.getMonth() + 1;
      const d = date.getDate();
      const weekDays = t('weekDays');
      const w = weekDays[date.getDay()];
      if (currentLang === 'zh') {
        return `<span class="date-left">${m}月${d}日</span><span class="date-right"><span class="date-year">${y}年</span><span class="date-week">周${w}</span></span>`;
      } else {
        const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
        return `<span class="date-left">${months[date.getMonth()]} ${d}</span><span class="date-right"><span class="date-year">${y}</span><span class="date-week">${w}</span></span>`;
      }
    }

    function getCurrentData() {
      const key = formatDate(currentDate);
      return database[key] || {};
    }

    function saveData() { localStorage.setItem('timeline_daily', JSON.stringify(database)); }
    function saveCategories() { localStorage.setItem('user_categories', JSON.stringify(userCategories)); }
    function savePlans() { localStorage.setItem('user_plans', JSON.stringify(userPlans)); }
    function saveSlotsPerHour() { localStorage.setItem('slots_per_hour', slotsPerHour.toString()); }
    function saveUndoHistory() { localStorage.setItem('undo_history', JSON.stringify(undoHistory)); }
    function saveSidebarState() { localStorage.setItem('sidebar_collapsed', sidebarCollapsed.toString()); }

    function loadData() {
      const savedLang = localStorage.getItem('app_language');
      if (savedLang) currentLang = savedLang;
      const savedCategories = localStorage.getItem('user_categories');
      if (savedCategories) {
        userCategories = JSON.parse(savedCategories);
        const hasSleepCategory = userCategories.some(c => c.id === 'preset_sleep' || c.name === '睡觉' || c.name === 'Sleep');
        if (!hasSleepCategory && userCategories.length < MAX_CATEGORIES) {
          userCategories.push({ id: 'preset_sleep', name: 'Sleep', class: COLOR_OPTIONS[6].class });
          saveCategories();
        }
      } else {
        userCategories = [...DEFAULT_CATEGORIES];
        saveCategories();
      }
      const savedPlans = localStorage.getItem('user_plans');
      if (savedPlans) userPlans = JSON.parse(savedPlans); else userPlans = [];
      const savedDatabase = localStorage.getItem('timeline_daily');
      if (savedDatabase) database = JSON.parse(savedDatabase);
      const savedSlots = localStorage.getItem('slots_per_hour');
      if (savedSlots) slotsPerHour = parseInt(savedSlots);
      const savedUndo = localStorage.getItem('undo_history');
      if (savedUndo) undoHistory = JSON.parse(savedUndo);
      const savedSidebarState = localStorage.getItem('sidebar_collapsed');
      if (savedSidebarState === 'true') {
        sidebarCollapsed = true;
        categorySidebar.classList.add('collapsed');
        sidebarToggle.classList.add('collapsed');
      }
      updateUndoButton();
    }

    function generateId() { return 'cat_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9); }
    function generatePlanId() { return 'plan_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9); }

    function copyToClipboard(text) {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(() => showCopyToast()).catch(() => fallbackCopy(text));
      } else fallbackCopy(text);
    }
    function fallbackCopy(text) {
      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();
      try { document.execCommand('copy'); showCopyToast(); } catch (err) {}
      document.body.removeChild(textarea);
    }
    function showCopyToast() {
      copyToast.textContent = t('copied');
      copyToast.classList.add('show');
      setTimeout(() => copyToast.classList.remove('show'), 2000);
    }

    function toggleSidebar() {
      sidebarCollapsed = !sidebarCollapsed;
      if (sidebarCollapsed) { categorySidebar.classList.add('collapsed'); sidebarToggle.classList.add('collapsed'); }
      else { categorySidebar.classList.remove('collapsed'); sidebarToggle.classList.remove('collapsed'); }
      saveSidebarState();
    }

    function pushUndoState() {
      const state = { date: formatDate(currentDate), data: JSON.parse(JSON.stringify(database)) };
      undoHistory.push(state);
      if (undoHistory.length > MAX_UNDO_HISTORY) undoHistory.shift();
      saveUndoHistory();
      updateUndoButton();
    }

    function undo() {
      if (undoHistory.length === 0) return;
      const lastState = undoHistory.pop();
      database = lastState.data;
      saveData();
      saveUndoHistory();
      renderTimeline();
      updateTodayStats();
      updateUndoButton();
    }

    function updateUndoButton() {
      if (undoHistory.length > 0) undoBtn.classList.add('active');
