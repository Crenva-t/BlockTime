        } else {
          point1Content = `Your average daily sleep duration is <span class="point-highlight">${avgSleepStr}</span>, which falls within the <span class="point-good">healthy range (7-10 hours)</span>. Great job! Adequate sleep duration is essential for physical and mental well-being. Keep it up!`;
