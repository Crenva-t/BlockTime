    function startLongPress(e, cat) {
      longPressTimer = setTimeout(() => { longPressedCategory = cat; showLongPressMenu(e); }, 500);
    }
    function cancelLongPress() { if (longPressTimer) { clearTimeout(longPressTimer); longPressTimer = null; } }
    function showLongPressMenu(e) {
      let clientX, clientY;
      if (e.touches) { clientX = e.touches[0].clientX; clientY = e.touches[0].clientY; }
      else { clientX = e.clientX; clientY = e.clientY; }
      longPressMenu.style.top = Math.min(clientY + 10, window.innerHeight - 150) + 'px';
      longPressMenu.style.left = Math.min(clientX - 60, window.innerWidth - 130) + 'px';
      longPressMenu.classList.remove('hidden');
    }
    function hideLongPressMenu() { longPressMenu.classList.add('hidden'); longPressedCategory = null; }

    function renderTimeline() {
      timelineContainer.innerHTML = '';
      const data = getCurrentData();
      for (let hour = 0; hour < 24; hour++) {
        const row = document.createElement('div');
        row.className = 'time-row';
        const label = document.createElement('div');
        label.className = 'time-label';
        label.textContent = String(hour).padStart(2, '0') + ':00';
        row.appendChild(label);
        const slotsContainer = document.createElement('div');
        slotsContainer.className = 'slots-container';
        for (let slotIndex = 0; slotIndex < slotsPerHour; slotIndex++) {
          const index = hour * slotsPerHour + slotIndex;
          const slot = document.createElement('div');
          slot.className = 'slot';
          slot.dataset.index = index;
          if (data[index]) {
            slot.classList.add(data[index].class);
            slot.textContent = slotsPerHour <= 3 ? data[index].label.slice(0, 2) : '';
          } else {
            slot.classList.add('empty');
          }
          slot.addEventListener('mousedown', (e) => { e.preventDefault(); startSelection(index); });
          slot.addEventListener('mousemove', (e) => { if (isSelecting) updateSelection(index); });
          slot.addEventListener('mouseup', () => endSelection());
          slot.addEventListener('touchstart', (e) => { e.preventDefault(); startSelection(index); }, { passive: false });
          slot.addEventListener('touchmove', (e) => {
            if (isSelecting) {
              const touch = e.touches[0];
              const element = document.elementFromPoint(touch.clientX, touch.clientY);
              if (element && element.classList.contains('slot')) updateSelection(parseInt(element.dataset.index));
            }
          }, { passive: false });
          slot.addEventListener('touchend', () => endSelection());
          slotsContainer.appendChild(slot);
        }
        row.appendChild(slotsContainer);
        timelineContainer.appendChild(row);
      }
      updateHighlight();
    }

    function startSelection(index) { isSelecting = true; selectionStart = index; selectionEnd = index; highlightedSlots.clear(); highlightedSlots.add(index); updateHighlight(); }
    function updateSelection(index) { if (!isSelecting) return; selectionEnd = index; const start = Math.min(selectionStart, selectionEnd); const end = Math.max(selectionStart, selectionEnd); highlightedSlots.clear(); for (let i = start; i <= end; i++) highlightedSlots.add(i); updateHighlight(); }
    function endSelection() { isSelecting = false; }
    function updateHighlight() { document.querySelectorAll('.slot').forEach(slot => { slot.classList.remove('highlight'); if (highlightedSlots.has(parseInt(slot.dataset.index))) slot.classList.add('highlight'); }); }

    function applyCategory(cat) {
      if (highlightedSlots.size === 0) return;
      pushUndoState();
      const key = formatDate(currentDate);
      if (!database[key]) database[key] = {};
      highlightedSlots.forEach(slotIndex => { database[key][slotIndex] = { label: cat.name, class: cat.class }; });
      saveData();
      renderTimeline();
      updateTodayStats();
      highlightedSlots.clear();
    }

    /* ============ Stats functions (V5.2.7) ============ */
    function getWeekDates() {
      const dates = [];
      const today = new Date();
      for (let i = 6; i >= 0; i--) {
        const date = new Date(today);
        date.setDate(today.getDate() - i);
        dates.push(date);
      }
      return dates;
    }

    function getSleepDataForWeek() {
      const weekDates = getWeekDates();
      const sleepData = [];
      const sleepCategory = userCategories.find(c => c.name === '睡觉' || c.name === 'Sleep' || c.id === 'preset_sleep');
      const restCategory = userCategories.find(c => c.name === '休息' || c.name === 'Rest' || c.id === 'preset_rest');
      const targetCategory = sleepCategory || restCategory;
      weekDates.forEach((date) => {
        const key = formatDate(date);
        const dayData = database[key] || {};
        const prevDate = new Date(date);
        prevDate.setDate(prevDate.getDate() - 1);
        const prevKey = formatDate(prevDate);
        const prevDayData = database[prevKey] || {};
        let totalSleepSlots = 0;
        let bedtimeSlot = -1;
        let wakeupSlot = -1;
        if (targetCategory) {
          const nightStartSlot = 21 * slotsPerHour;
          const nightEndSlot = 28 * slotsPerHour;
          for (let idx = nightStartSlot; idx < nightEndSlot; idx++) {
            if (prevDayData[idx] && prevDayData[idx].class === targetCategory.class) {
              if (bedtimeSlot === -1) bedtimeSlot = idx;
              totalSleepSlots++;
            }
          }
          const morningEndSlot = 12 * slotsPerHour;
          let lastSleepSlot = -1;
          for (let idx = 0; idx < morningEndSlot; idx++) {
            if (dayData[idx] && dayData[idx].class === targetCategory.class) {
              if (bedtimeSlot === -1) bedtimeSlot = idx;
              totalSleepSlots++;
              lastSleepSlot = idx;
            }
          }
          if (lastSleepSlot !== -1) wakeupSlot = lastSleepSlot + 1;
          if (bedtimeSlot === -1) {
            for (let idx = nightStartSlot; idx < nightEndSlot; idx++) {
              if (dayData[idx] && dayData[idx].class === targetCategory.class) { bedtimeSlot = idx; break; }
            }
          }
        }
        const minutesPerSlot = 60 / slotsPerHour;
        const sleepHours = (totalSleepSlots * minutesPerSlot) / 60;
        let bedtimeHour = null;
        if (bedtimeSlot !== -1) {
          let rawHour = Math.floor(bedtimeSlot / slotsPerHour) + (bedtimeSlot % slotsPerHour) / slotsPerHour;
          if (rawHour < 12) rawHour += 24;
          bedtimeHour = rawHour;
        }
        sleepData.push({ date, sleepHours, bedtimeHour, wakeupSlot });
      });
      return sleepData;
    }

