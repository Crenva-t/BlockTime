    function savePlan() {
      const cycle = document.getElementById('planCycleSelect').value;
      const categoryId = document.getElementById('planCategorySelect').value;
      const compareType = document.getElementById('planCompareSelect').value;
      const targetHours = parseFloat(document.getElementById('planTargetHours').value) || 1;
      if (!categoryId) { alert('Please select a category'); return; }
      const name = generatePlanPreviewName();
      const planData = {
        id: planEditMode === 'add' ? generatePlanId() : editingPlanId,
        name, colorClass: selectedPlanColorClass, cycle, categoryId, compareType, targetHours
      };
      if (planEditMode === 'add') userPlans.push(planData);
      else {
        const idx = userPlans.findIndex(p => p.id === editingPlanId);
        if (idx !== -1) userPlans[idx] = planData;
