        type: 'line',
        data: { labels, datasets: [{ data: values, borderColor: '#FA7298', backgroundColor: 'rgba(250,114,152,0.1)', fill: true, tension: 0.3, pointBackgroundColor: '#FA7298', pointRadius: 4 }] },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { min: 20, max: 28, ticks: { callback: v => { const hour = v >= 24 ? v - 24 : v; return String(Math.floor(hour)).padStart(2, '0') + ':00'; } } } } }
      });
