    /* ============ Plans (Mini5.3.7) ============ */
    function getCategoryHours(dateKey, categoryId) {
      const dayData = database[dateKey] || {};
      const category = userCategories.find(c => c.id === categoryId);
      if (!category) return 0;
      let count = 0;
      for (let i = 0; i < 24 * slotsPerHour; i++) {
        if (dayData[i] && dayData[i].class === category.class) count++;
      }
      return (count * (60 / slotsPerHour)) / 60;
    }

    function computePlanStreak(plan) {
      if (!plan.categoryId || !userCategories.some(c => c.id === plan.categoryId)) return 0;
      const today = new Date();
      let streakDays = 0;
      const checkDate = new Date(today);
      checkDate.setDate(checkDate.getDate() - 1);
      const maxDaysBack = 365;
      for (let i = 0; i < maxDaysBack; i++) {
        const dateKey = formatDate(checkDate);
        const hours = getCategoryHours(dateKey, plan.categoryId);
        let conditionMet = false;
        if (plan.compareType === 'greater') conditionMet = hours > plan.targetHours;
        else conditionMet = hours < plan.targetHours;
        if (conditionMet) { streakDays++; checkDate.setDate(checkDate.getDate() - 1); }
        else break;
      }
      return streakDays;
    }

    function getStreakText(plan) {
      const totalDays = computePlanStreak(plan);
      if (plan.cycle === 'weekly') {
        const weeks = Math.floor(totalDays / 7);
        return t('streakWeeks').replace('{weeks}', weeks);
      } else if (plan.cycle === 'monthly') {
        const months = Math.floor(totalDays / 30);
        return t('streakMonths').replace('{months}', months);
      } else {
        return t('streakDays').replace('{days}', totalDays);
      }
    }

