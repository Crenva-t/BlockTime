    function renderTimeline() {
      timelineContainer.innerHTML = '';
      const data = getCurrentData();

      for (let hour = 0; hour < 24; hour++) {
        const row = document.createElement('div');
        row.className = 'time-row';

        const label = document.createElement('div');
        label.className = 'time-label';
        label.textContent = String(hour).padStart(2, '0') + ':00';
        row.appendChild(label);

        const slotsContainer = document.createElement('div');
        slotsContainer.className = 'slots-container';

        for (let slotIndex = 0; slotIndex < slotsPerHour; slotIndex++) {
          const index = hour * slotsPerHour + slotIndex;
          const slot = document.createElement('div');
          slot.className = 'slot';
          slot.dataset.index = index;

          if (data[index]) {
            slot.classList.add(data[index].class);
            slot.textContent = slotsPerHour <= 3 ? data[index].label.slice(0, 2) : '';
          } else {
            slot.classList.add('empty');
          }

          slot.addEventListener('mousedown', (e) => {
            e.preventDefault();
            startSelection(index);
          });
          slot.addEventListener('mousemove', (e) => {
            if (isSelecting) {
              updateSelection(index);
            }
          });
          slot.addEventListener('mouseup', () => {
            endSelection();
          });

          slot.addEventListener('touchstart', (e) => {
            e.preventDefault();
            startSelection(index);
          }, { passive: false });
          slot.addEventListener('touchmove', (e) => {
            if (isSelecting) {
              const touch = e.touches[0];
              const element = document.elementFromPoint(touch.clientX, touch.clientY);
              if (element && element.classList.contains('slot')) {
                updateSelection(parseInt(element.dataset.index));
              }
            }
          }, { passive: false });
          slot.addEventListener('touchend', () => {
            endSelection();
          });

          slotsContainer.appendChild(slot);
        }

        row.appendChild(slotsContainer);
        timelineContainer.appendChild(row);
      }

      updateHighlight();
    }

    function startSelection(index) {
      isSelecting = true;
      selectionStart = index;
      selectionEnd = index;
      highlightedSlots.clear();
      highlightedSlots.add(index);
      updateHighlight();
    }

    function updateSelection(index) {
      if (!isSelecting) return;
      selectionEnd = index;

      const start = Math.min(selectionStart, selectionEnd);
      const end = Math.max(selectionStart, selectionEnd);

      highlightedSlots.clear();
      for (let i = start; i <= end; i++) {
        highlightedSlots.add(i);
      }
      updateHighlight();
    }

    function endSelection() {
      isSelecting = false;
    }

    function updateHighlight() {
      document.querySelectorAll('.slot').forEach(slot => {
        slot.classList.remove('highlight');
        const index = parseInt(slot.dataset.index);
        if (highlightedSlots.has(index)) {
          slot.classList.add('highlight');
        }
      });
    }

    function applyCategory(cat) {
      if (highlightedSlots.size === 0) return;

      pushUndoState();

      const key = formatDate(currentDate);
      if (!database[key]) {
        database[key] = {};
      }

      highlightedSlots.forEach(slotIndex => {
        database[key][slotIndex] = {
          label: cat.name,
          class: cat.class
        };
      });

      saveData();
      renderTimeline();
      updateStats();
      highlightedSlots.clear();
    }

    function updateStats() {
      const data = getCurrentData();
      const stats = {};

      userCategories.forEach(cat => {
        stats[cat.id] = { name: cat.name, class: cat.class, count: 0 };
      });

      Object.values(data).forEach(slot => {
        const cat = userCategories.find(c => c.class === slot.class);
        if (cat && stats[cat.id]) {
          stats[cat.id].count++;
        }
      });

      document.getElementById('statsDate').textContent = formatStatsDate(currentDate);

      const totalSlots = Object.values(data).length;
      const minutesPerSlot = 60 / slotsPerHour;
      const totalMinutes = totalSlots * minutesPerSlot;
      const totalHours = Math.floor(totalMinutes / 60);
      const totalMins = Math.round(totalMinutes % 60);

      document.getElementById('totalRecorded').textContent = totalHours > 0 ? `${totalHours}h${totalMins}m` :
      `${totalMins}m`;

      // 计算本周睡眠数据并更新统计顶部的睡眠指标
      const sleepData = getSleepDataForWeek();
      const validSleepData = sleepData.filter(d => d.sleepHours > 0);
      const validBedtimeData = sleepData.filter(d => d.bedtimeHour !== null);
      const validWakeupData = sleepData.filter(d => d.wakeupSlot !== -1 && d.wakeupSlot !== undefined && d.wakeupSlot >
        0);

      if (validSleepData.length > 0) {
        const avgSleep = validSleepData.reduce((sum, d) => sum + d.sleepHours, 0) / validSleepData.length;
        const avgHours = Math.floor(avgSleep);
        const avgMins = Math.round((avgSleep - avgHours) * 60);
        document.getElementById('avgSleepDurationStats').textContent = `${avgHours}h${avgMins}m`;
      } else {
        document.getElementById('avgSleepDurationStats').textContent = '--';
      }

      if (validBedtimeData.length > 0) {
        const avgBedtime = validBedtimeData.reduce((sum, d) => sum + d.bedtimeHour, 0) / validBedtimeData.length;
        const bedHour = Math.floor(avgBedtime);
        const bedMin = Math.round((avgBedtime - bedHour) * 60);
        document.getElementById('avgBedtimeStats').textContent =
          `${String(bedHour).padStart(2, '0')}:${String(bedMin).padStart(2, '0')}`;
      } else {
        document.getElementById('avgBedtimeStats').textContent = '--';
      }

      if (validWakeupData.length > 0) {
        const avgWakeupSlot = validWakeupData.reduce((sum, d) => sum + d.wakeupSlot, 0) / validWakeupData.length;
        const wakeupHour = Math.floor(avgWakeupSlot / slotsPerHour);
        const wakeupMin = Math.round((avgWakeupSlot % slotsPerHour) * (60 / slotsPerHour));
        document.getElementById('avgWakeupStats').textContent =
          `${String(wakeupHour).padStart(2, '0')}:${String(wakeupMin).padStart(2, '0')}`;
      } else {
        document.getElementById('avgWakeupStats').textContent = '--';
      }

      statsList.innerHTML = '';
      const hasData = Object.values(stats).some(s => s.count > 0);

      if (!hasData) {
        statsList.innerHTML = `
          <div class="no-data">
            <div>${t('noRecordToday')}</div>
          </div>
        `;
      } else {
        const sortedStats = Object.values(stats).filter(s => s.count > 0).sort((a, b) => b.count - a.count);

        sortedStats.forEach(s => {
          const minutes = s.count * minutesPerSlot;
          const hours = Math.floor(minutes / 60);
          const mins = Math.round(minutes % 60);
          const timeStr = hours > 0 ? `${hours}h${mins}m` : `${mins}m`;
          const percent = totalSlots > 0 ? Math.round((s.count / totalSlots) * 100) : 0;

          const item = document.createElement('div');
          item.className = 'stats-item';

          const colorOption = COLOR_OPTIONS.find(c => c.class === s.class);
          const bgColor = colorOption ? colorOption.bg : '#94a3b8';

          item.innerHTML = `
            <div class="stats-color" style="background: ${bgColor}"></div>
            <div class="stats-name">${s.name}</div>
            <div class="stats-time">${timeStr}</div>
            <div class="stats-percent">${percent}%</div>
          `;
          statsList.appendChild(item);
        });
      }

      renderPieChart(stats);
    }

    function renderPieChart(stats) {
      const ctx = document.getElementById('pieChart').getContext('2d');

      const chartData = Object.values(stats).filter(s => s.count > 0);

      if (pieChart) {
        pieChart.destroy();
      }

      if (chartData.length === 0) {
        return;
      }

      const minutesPerSlot = 60 / slotsPerHour;
      const labels = chartData.map(s => s.name);
      const values = chartData.map(s => s.count * minutesPerSlot);
      const colors = chartData.map(s => {
        const colorOption = COLOR_OPTIONS.find(c => c.class === s.class);
        return colorOption ? colorOption.bg : '#94a3b8';
      });

      pieChart = new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: labels,
          datasets: [{
            data: values,
            backgroundColor: colors,
            borderWidth: 2,
            borderColor: '#ffffff'
          }]
        },
        options: {
          responsive: true,
          cutout: '60%',
          plugins: {
            legend: {
              display: false
            }
          }
        }
      });
    }

    // Sleep page functions
    function getWeekDates() {
      const dates = [];
      const today = new Date();
      for (let i = 6; i >= 0; i--) {
        const date = new Date(today);
        date.setDate(today.getDate() - i);
        dates.push(date);
      }
      return dates;
    }

    function getSleepDataForWeek() {
      const weekDates = getWeekDates();
      const sleepData = [];
      // 优先查找"睡觉/Sleep"分类，如果没有则回退到"休息/Rest"分类
      const sleepCategory = userCategories.find(c => c.name === '睡觉' || c.name === 'Sleep' || c.id === 'preset_sleep');
      const restCategory = userCategories.find(c => c.name === '休息' || c.name === 'Rest' || c.id === 'preset_rest');
      const targetCategory = sleepCategory || restCategory;

      weekDates.forEach((date, dateIndex) => {
        const key = formatDate(date);
        const dayData = database[key] || {};

        // 获取前一天的数据（用于计算跨夜睡眠）
        const prevDate = new Date(date);
        prevDate.setDate(prevDate.getDate() - 1);
        const prevKey = formatDate(prevDate);
        const prevDayData = database[prevKey] || {};

        let totalSleepSlots = 0;
        let bedtimeSlot = -1;
        let wakeupSlot = -1;

        if (targetCategory) {
          // 查找前一天晚上的睡眠起点（21:00-23:59）
          const nightStartSlot = 21 * slotsPerHour;
          const nightEndSlot = 24 * slotsPerHour;

          // 检查前一天晚上的睡眠
          for (let idx = nightStartSlot; idx < nightEndSlot; idx++) {
            if (prevDayData[idx] && prevDayData[idx].class === targetCategory.class) {
              if (bedtimeSlot === -1) {
                bedtimeSlot = idx;
              }
              totalSleepSlots++;
            }
          }

          // 检查当天早晨的睡眠（00:00-12:00）
          const morningEndSlot = 12 * slotsPerHour;
          let lastSleepSlot = -1;
          for (let idx = 0; idx < morningEndSlot; idx++) {
            if (dayData[idx] && dayData[idx].class === targetCategory.class) {
              totalSleepSlots++;
              lastSleepSlot = idx;
            }
          }
          // 起床时间是最后一个睡眠slot结束后的时间
          if (lastSleepSlot !== -1) {
            wakeupSlot = lastSleepSlot + 1;
          }

          // 如果前一天晚上没有找到睡眠起点，检查当天晚上（用于显示当天的入睡时间）
          if (bedtimeSlot === -1) {
            for (let idx = nightStartSlot; idx < nightEndSlot; idx++) {
              if (dayData[idx] && dayData[idx].class === targetCategory.class) {
                bedtimeSlot = idx;
                break;
              }
            }
          }
        }

        const minutesPerSlot = 60 / slotsPerHour;
        const sleepMinutes = totalSleepSlots * minutesPerSlot;
        const sleepHours = sleepMinutes / 60;

        // 计算入睡时间
        let bedtimeHour = null;
        if (bedtimeSlot !== -1) {
          bedtimeHour = Math.floor(bedtimeSlot / slotsPerHour) + (bedtimeSlot % slotsPerHour) / slotsPerHour;
        }

        sleepData.push({
          date: date,
          sleepHours: sleepHours,
          bedtimeHour: bedtimeHour,
          wakeupSlot: wakeupSlot
        });
      });

      return sleepData;
    }

    function updateSleepPage() {
      const sleepData = getSleepDataForWeek();
      const weekDays = t('weekDays');

      // Render bar chart
      renderSleepBarChart(sleepData, weekDays);

      // Render line chart
      renderBedtimeLineChart(sleepData, weekDays);

      // 重置睡眠建议显示状态
      document.getElementById('sleepAdviceContent').style.display = 'none';
      document.getElementById('generateAdviceBtn').style.display = 'flex';
    }

    function renderSleepBarChart(sleepData, weekDays) {
      const ctx = document.getElementById('sleepBarChart').getContext('2d');

      if (sleepBarChart) {
        sleepBarChart.destroy();
      }

      const labels = sleepData.map(d => weekDays[d.date.getDay()]);
      const values = sleepData.map(d => d.sleepHours);

      sleepBarChart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{
            data: values,
            backgroundColor: '#6C70DB',
            borderRadius: 4
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: false
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              max: 12,
              ticks: {
                callback: function(value) {
                  return value + 'h';
                }
              }
            }
          }
        }
      });
    }

    function renderBedtimeLineChart(sleepData, weekDays) {
      const ctx = document.getElementById('bedtimeLineChart').getContext('2d');

      if (bedtimeLineChart) {
        bedtimeLineChart.destroy();
      }

      const labels = sleepData.map(d => weekDays[d.date.getDay()]);
      const values = sleepData.map(d => d.bedtimeHour);

      bedtimeLineChart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [{
            data: values,
            borderColor: '#FA7298',
            backgroundColor: 'rgba(250, 114, 152, 0.1)',
            fill: true,
            tension: 0.3,
            pointBackgroundColor: '#FA7298',
            pointRadius: 4
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: false
            }
          },
          scales: {
            y: {
              min: 20,
              max: 26,
              ticks: {
                callback: function(value) {
                  const hour = value >= 24 ? value - 24 : value;
                  return String(Math.floor(hour)).padStart(2, '0') + ':00';
                }
              }
            }
          }
        }
      });
    }

    function generateSleepAdvice() {
      const sleepData = getSleepDataForWeek();
      const validSleepData = sleepData.filter(d => d.sleepHours > 0);

      if (validSleepData.length === 0) {
        alert(t('noSleepData'));
        return;
      }

      const avgSleep = validSleepData.reduce((sum, d) => sum + d.sleepHours, 0) / validSleepData.length;
      const validBedtimeData = sleepData.filter(d => d.bedtimeHour !== null);
      const avgBedtime = validBedtimeData.length > 0 ?
        validBedtimeData.reduce((sum, d) => sum + d.bedtimeHour, 0) / validBedtimeData.length : null;

      let advice = '';

      if (currentLang === 'zh') {
        advice = `<div class="sleep-advice-title">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"></path>
          </svg>
          ${t('sleepAdviceTitle')}
        </div>`;

        if (avgSleep < 6) {
          advice += '<p>您的平均睡眠时间不足6小时，这可能会严重影响您的健康和学习效率。建议：</p>';
          advice +=
            '<ul style="margin: 8px 0; padding-left: 20px;"><li>尽量在23:00前上床</li><li>减少睡前使用手机的时间</li><li>如果学业繁忙，考虑优化时间管理</li></ul>';
        } else if (avgSleep < 7) {
          advice += '<p>您的睡眠时间略显不足。成年人建议每天睡眠7-9小时。建议：</p>';
          advice +=
            '<ul style="margin: 8px 0; padding-left: 20px;"><li>尝试提前30分钟入睡</li><li>保持规律的作息时间</li><li>睡前避免剧烈运动和咖啡因</li></ul>';
        } else if (avgSleep <= 9) {
          advice += '<p>您的睡眠时间在健康范围内，继续保持！建议：</p>';
          advice +=
            '<ul style="margin: 8px 0; padding-left: 20px;"><li>保持现有的良好作息</li><li>注意睡眠质量的提升</li><li>如有困倦，可适当午休20-30分钟</li></ul>';
        } else {
          advice += '<p>您的睡眠时间较长，过多睡眠可能会导致白天精力不足。建议：</p>';
          advice +=
            '<ul style="margin: 8px 0; padding-left: 20px;"><li>设定固定的起床时间</li><li>增加白天的活动量</li><li>检查是否有其他健康问题</li></ul>';
        }

        if (avgBedtime !== null) {
          if (avgBedtime >= 24 || avgBedtime < 1) {
            advice += '<p style="margin-top: 12px;">您的平均入睡时间在午夜左右，建议尝试提前入睡以获得更好的睡眠质量。</p>';
          } else if (avgBedtime >= 1) {
            advice += '<p style="margin-top: 12px;">您的入睡时间较晚，这可能影响第二天的精力。建议逐步将入睡时间提前至23:00左右。</p>';
          }
        }
      } else {
        advice = `<div class="sleep-advice-title">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"></path>
          </svg>
          ${t('sleepAdviceTitle')}
        </div>`;

        if (avgSleep < 6) {
          advice +=
            '<p>Your average sleep is less than 6 hours, which may seriously affect your health and learning efficiency. Suggestions:</p>';
          advice +=
            '<ul style="margin: 8px 0; padding-left: 20px;"><li>Try to go to bed before 11 PM</li><li>Reduce phone usage before bed</li><li>Consider optimizing time management if busy with studies</li></ul>';
        } else if (avgSleep < 7) {
          advice +=
            '<p>Your sleep duration is slightly insufficient. Adults are recommended to sleep 7-9 hours daily. Suggestions:</p>';
          advice +=
            '<ul style="margin: 8px 0; padding-left: 20px;"><li>Try going to bed 30 minutes earlier</li><li>Maintain a regular sleep schedule</li><li>Avoid intense exercise and caffeine before bed</li></ul>';
        } else if (avgSleep <= 9) {
          advice += '<p>Your sleep duration is within the healthy range, keep it up! Suggestions:</p>';
          advice +=
            '<ul style="margin: 8px 0; padding-left: 20px;"><li>Maintain your good sleep habits</li><li>Focus on improving sleep quality</li><li>A 20-30 minute nap is okay if feeling tired</li></ul>';
        } else {
          advice +=
            '<p>Your sleep duration is quite long. Excessive sleep may lead to daytime fatigue. Suggestions:</p>';
          advice +=
            '<ul style="margin: 8px 0; padding-left: 20px;"><li>Set a fixed wake-up time</li><li>Increase daytime activities</li><li>Check for other health issues</li></ul>';
        }

        if (avgBedtime !== null) {
          if (avgBedtime >= 24 || avgBedtime < 1) {
            advice +=
              '<p style="margin-top: 12px;">Your average bedtime is around midnight. Consider going to bed earlier for better sleep quality.</p>';
          } else if (avgBedtime >= 1) {
            advice +=
              '<p style="margin-top: 12px;">Your bedtime is quite late, which may affect next-day energy. Try gradually moving bedtime to around 11 PM.</p>';
          }
        }
      }

      const adviceContent = document.getElementById('sleepAdviceContent');
      adviceContent.innerHTML = advice;
      adviceContent.style.display = 'block';
      document.getElementById('generateAdviceBtn').style.display = 'none';
    }

    function renderArticleList() {
      const articleList = document.getElementById('articleList');
      const articles = t('articles');

      articleList.innerHTML = '';
      articles.forEach((article, index) => {
        const item = document.createElement('div');
        item.className = 'article-item';
        item.innerHTML = `
          <div class="article-item-title">${article.title}</div>
          <div class="article-item-desc">${article.desc}</div>
        `;
        item.addEventListener('click', () => openArticle(index));
        articleList.appendChild(item);
      });
    }

    function openArticle(index) {
      const articles = t('articles');
      const contents = t('articleContents');

      document.getElementById('articleModalTitle').textContent = articles[index].title;
      document.getElementById('articleModalContent').textContent = contents[index];
      articleModal.classList.remove('hidden');
    }

    function changeDate(offset) {
      currentDate.setDate(currentDate.getDate() + offset);
      currentDateDisplay.innerHTML = formatDateDisplay(currentDate);
      highlightedSlots.clear();
      renderTimeline();
      updateStats();
    }

    function openAddModal() {
      if (userCategories.length >= MAX_CATEGORIES) {
        alert(t('maxCategoriesReached'));
        return;
      }
      editMode = 'add';
      document.getElementById('modalTitle').textContent = t('addCategory');
      document.getElementById('categoryNameInput').value = '';
      document.getElementById('categoryNameInput').placeholder = t('inputPlaceholder');
      selectedColorClass = COLOR_OPTIONS[0].class;
      renderColorOptions();
      editModal.classList.remove('hidden');
    }

    function openEditModal() {
      if (!longPressedCategory) return;
      editMode = 'edit';
      document.getElementById('modalTitle').textContent = t('editCategory');
      document.getElementById('categoryNameInput').value = longPressedCategory.name;
      document.getElementById('categoryNameInput').placeholder = t('inputPlaceholder');
      selectedColorClass = longPressedCategory.class;
      renderColorOptions();
      editModal.classList.remove('hidden');
      hideLongPressMenu();
    }

    function renderColorOptions() {
      const container = document.getElementById('colorOptions');
      container.innerHTML = '';

      COLOR_OPTIONS.forEach(color => {
        const div = document.createElement('div');
        div.className = `color-option ${color.class}`;
        if (color.class === selectedColorClass) {
          div.classList.add('selected');
        }
        div.addEventListener('click', () => {
          selectedColorClass = color.class;
          renderColorOptions();
        });
        container.appendChild(div);
      });
    }

    function saveCategory() {
      let name = document.getElementById('categoryNameInput').value.trim();
      if (!name) {
        alert(t('enterCategoryName'));
        return;
      }

      if (name.length > MAX_NAME_LENGTH) {
        name = name.slice(0, MAX_NAME_LENGTH);
      }

      if (editMode === 'add') {
        const newCat = {
          id: generateId(),
          name: name,
          class: selectedColorClass
        };
        userCategories.push(newCat);
      } else {
        const index = userCategories.findIndex(c => c.id === longPressedCategory.id);
        if (index !== -1) {
          userCategories[index].name = name;
          userCategories[index].class = selectedColorClass;
        }
      }

      saveCategories();
      renderCategorySidebar();
      renderTimeline();
      updateStats();
      editModal.classList.add('hidden');
    }

    function deleteCategory() {
      if (!longPressedCategory) return;
      const index = userCategories.findIndex(c => c.id === longPressedCategory.id);
      if (index !== -1) {
        userCategories.splice(index, 1);
        saveCategories();
        renderCategorySidebar();
        updateStats();
      }
      hideLongPressMenu();
    }

    function clearToday() {
      pushUndoState();

      const key = formatDate(currentDate);
      database[key] = {};
      saveData();
      renderTimeline();
      updateStats();
      highlightedSlots.clear();
      hideDropdownMenu();
    }

    function toggleDropdownMenu() {
      dropdownMenu.classList.toggle('hidden');
    }

    function hideDropdownMenu() {
      dropdownMenu.classList.add('hidden');
    }

    function updateBlockSizeButtons() {
      document.querySelectorAll('.block-size-btn').forEach(btn => {
        btn.classList.remove('active');
        if (parseInt(btn.dataset.size) === slotsPerHour) {
          btn.classList.add('active');
        }
      });
    }

    function setBlockSize(size) {
      slotsPerHour = size;
      saveSlotsPerHour();
      updateBlockSizeButtons();
      renderTimeline();
      updateStats();
    }

    function showGuideIfNeeded() {
      const shown = localStorage.getItem('guide_shown');
      if (!shown) {
        guideTip.textContent = t('guideTip');
        guideTip.classList.remove('hidden');
        setTimeout(() => {
          guideTip.classList.add('hidden');
          localStorage.setItem('guide_shown', '1');
        }, 5000);
        guideTip.addEventListener('click', () => {
          guideTip.classList.add('hidden');
          localStorage.setItem('guide_shown', '1');
        });
      }
    }

    function showPage(page) {
      timelinePage.classList.add('hidden');
      statsPage.classList.add('hidden');
      sleepPage.classList.add('hidden');
      aboutPage.classList.add('hidden');
      tabTimeline.classList.remove('active');
      tabSleep.classList.remove('active');
      tabStats.classList.remove('active');
      tabAbout.classList.remove('active');

      if (page === 'timeline') {
        timelinePage.classList.remove('hidden');
        tabTimeline.classList.add('active');
      } else if (page === 'sleep') {
        sleepPage.classList.remove('hidden');
        tabSleep.classList.add('active');
        updateSleepPage();
      } else if (page === 'stats') {
        statsPage.classList.remove('hidden');
        tabStats.classList.add('active');
        updateStats();
      } else if (page === 'about') {
        aboutPage.classList.remove('hidden');
        tabAbout.classList.add('active');
      }
    }

    function init() {
      loadData();
      updateAllText();
      currentDateDisplay.innerHTML = formatDateDisplay(currentDate);
      updateBlockSizeButtons();
      renderCategorySidebar();
      renderTimeline();
      updateStats();
      renderArticleList();
      showGuideIfNeeded();

      // 检查睡眠提示是否已被关闭
      const tipDismissed = localStorage.getItem('sleep_tip_dismissed');
      if (tipDismissed === 'true') {
        document.getElementById('sleepTip').style.display = 'none';
      }

      // 关闭按钮事件
      document.getElementById('dismissSleepTip').addEventListener('click', function() {
        document.getElementById('sleepTip').style.display = 'none';
        localStorage.setItem('sleep_tip_dismissed', 'true');
      });

      document.getElementById('prevDay').addEventListener('click', () => changeDate(-1));
      document.getElementById('nextDay').addEventListener('click', () => changeDate(1));

      undoBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        undo();
      });

      document.getElementById('langBtn').addEventListener('click', (e) => {
        e.stopPropagation();
        toggleLanguage();
      });

      sidebarToggle.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleSidebar();
      });

      document.getElementById('menuToggle').addEventListener('click', (e) => {
        e.stopPropagation();
        toggleDropdownMenu();
      });

      document.getElementById('clearTodayBtn').addEventListener('click', clearToday);

      document.querySelectorAll('.block-size-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          setBlockSize(parseInt(btn.dataset.size));
        });
      });

      tabTimeline.addEventListener('click', () => showPage('timeline'));
      tabSleep.addEventListener('click', () => showPage('sleep'));
      tabStats.addEventListener('click', () => showPage('stats'));
      tabAbout.addEventListener('click', () => showPage('about'));

      document.getElementById('menuEdit').addEventListener('click', () => {
        if (longPressedCategory) {
          openEditModal();
        }
      });
      document.getElementById('menuDelete').addEventListener('click', () => {
        deleteCategory();
      });
      document.getElementById('menuCancel').addEventListener('click', hideLongPressMenu);

      document.addEventListener('click', (e) => {
        if (!longPressMenu.contains(e.target)) {
          hideLongPressMenu();
        }
        if (!dropdownMenu.contains(e.target) && e.target.id !== 'menuToggle' && !e.target.closest(
          '#menuToggle')) {
          hideDropdownMenu();
        }
      });

      document.addEventListener('mouseup', () => {
        isSelecting = false;
      });

      document.getElementById('modalCancel').addEventListener('click', () => {
        editModal.classList.add('hidden');
      });
      document.getElementById('modalSave').addEventListener('click', saveCategory);

      document.getElementById('articleModalClose').addEventListener('click', () => {
        articleModal.classList.add('hidden');
      });

      document.addEventListener('click', (e) => {
        if (!e.target.closest('.slot') && !e.target.closest('.cat-item') && !e.target.closest(
          '.timeline-container')) {
          highlightedSlots.clear();
          updateHighlight();
        }
      });

      document.getElementById('categoryNameInput').addEventListener('input', (e) => {
        if (e.target.value.length > MAX_NAME_LENGTH) {
          e.target.value = e.target.value.slice(0, MAX_NAME_LENGTH);
        }
      });

      document.getElementById('connectLink').addEventListener('click', () => {
        copyToClipboard('https://connect.xjtlu.edu.cn/group/ay2526-lif001-b68?login');
      });

      document.getElementById('githubLink').addEventListener('click', () => {
        copyToClipboard('https://github.com/Crenva-t/BlockTime');
      });

      document.getElementById('generateAdviceBtn').addEventListener('click', generateSleepAdvice);
    }

    init();
  </script>
</body>
</html>
