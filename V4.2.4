<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>LIF B68 Project</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js">
  </script>
  <!--
  Developed by LIF Group B68, serving the topic: Developing Healthy Sleep Habits in College Students.
  Unauthorized commercial use is prohibited. Please credit the source if redistributed.

