  <div id="longPressMenu" class="long-press-menu hidden">
    <button id="menuEdit">编辑</button>
    <button id="menuDelete" class="danger">删除</button>
    <button id="menuCancel">取消</button>
  </div>

  <div id="editModal" class="modal hidden">
    <div class="modal-card">
      <h3 id="modalTitle">添加分类</h3>
      <input type="text" id="categoryNameInput" placeholder="输入分类名称" maxlength="4">
      <div class="input-hint">最多4个字符</div>
      <div id="colorOptions" class="color-options"></div>
      <div class="modal-buttons">
        <button id="modalCancel" class="btn-cancel">取消</button>
        <button id="modalSave" class="btn-save">保存</button>
      </div>
    </div>
  </div>

  <div id="guideTip" class="guide-tip hidden">
    长按分类可编辑或删除哦。
  </div>

  <script>
    // 最大分类数量
    const MAX_CATEGORIES = 12;
    // 最大事件名称长度
    const MAX_NAME_LENGTH = 4;

    // 12种颜色选项
    const COLOR_OPTIONS = [
      { name: '玫瑰红', class: 'color-custom-1', bg: '#F16D7A' },
      { name: '橙色',   class: 'color-custom-2', bg: '#FD823F' },
      { name: '金色',   class: 'color-custom-3', bg: '#E1BF1F' },
      { name: '绿色',   class: 'color-custom-4', bg: '#A4B229' },
      { name: '青绿',   class: 'color-custom-5', bg: '#24AEB8' },
      { name: '蓝色',   class: 'color-custom-6', bg: '#1E88C6' },
      { name: '深蓝',   class: 'color-custom-7', bg: '#6C70DB' },
      { name: '淡紫',   class: 'color-custom-8', bg: '#9B85CD' },
      { name: '紫色',   class: 'color-custom-9', bg: '#BC70EC' },
      { name: '粉色',   class: 'color-custom-10', bg: '#DD65AF' },
      { name: '灰绿',   class: 'color-custom-11', bg: '#879ACE' },
      { name: '灰蓝',   class: 'color-custom-12', bg: '#5E7B81' }
    ];

    // 默认预设分类
    const DEFAULT_CATEGORIES = [
      { id: 'preset_learn',  name: '学习', class: COLOR_OPTIONS[5].class },
      { id: 'preset_sport',  name: '运动', class: COLOR_OPTIONS[1].class },
      { id: 'preset_entertain', name: '娱乐', class: COLOR_OPTIONS[8].class },
      { id: 'preset_interest', name: '兴趣', class: COLOR_OPTIONS[4].class },
      { id: 'preset_rest',   name: '休息', class: COLOR_OPTIONS[11].class },
      { id: 'preset_eat',    name: '餐饮', class: COLOR_OPTIONS[9].class }
    ];

    // 数据
    let userCategories = [];
    let database = {};
    let currentDate = new Date();
    let highlightedSlot = null;
    let longPressedCategory = null;
    let longPressTimer = null;
    let editMode = 'add';
    let selectedColorClass = COLOR_OPTIONS[0].class;
    let pieChart = null;
    let slotsPerHour = 4;
    let sidebarCollapsed = false;

    // 撤销历史记录
    let undoHistory = [];
    const MAX_UNDO_HISTORY = 50;

    // DOM元素
    const categorySidebar = document.getElementById('categorySidebar');
    const timelineContainer = document.getElementById('timelineContainer');
    const currentDateDisplay = document.getElementById('currentDateDisplay');
    const timelinePage = document.getElementById('timelinePage');
    const statsPage = document.getElementById('statsPage');
    const aboutPage = document.getElementById('aboutPage');
    const tabTimeline = document.getElementById('tabTimeline');
    const tabStats = document.getElementById('tabStats');
    const tabAbout = document.getElementById('tabAbout');
    const longPressMenu = document.getElementById('longPressMenu');
    const editModal = document.getElementById('editModal');
    const guideTip = document.getElementById('guideTip');
    const statsList = document.getElementById('statsList');
    const dropdownMenu = document.getElementById('dropdownMenu');
    const undoBtn = document.getElementById('undoBtn');
    const sidebarToggle = document.getElementById('sidebarToggle');

    // 工具函数
    function formatDate(date) {
      const y = date.getFullYear();
      const m = String(date.getMonth() + 1).padStart(2, '0');
      const d = String(date.getDate()).padStart(2, '0');
      return `${y}-${m}-${d}`;
    }

    function formatDateDisplay(date) {
      const y = date.getFullYear();
      const m = date.getMonth() + 1;
      const d = date.getDate();
      const weekDays = ['日','一', '二', '三', '四', '五', '六'];
      const w = weekDays[date.getDay()];

      return `
        <span class="date-left">${m}月${d}日</span>
        <span class="date-right">
          <span class="date-year">${y}年</span>
          <span class="date-week">周${w}</span>
        </span>
      `;
    }

    function formatStatsDate(date) {
      const y = date.getFullYear();
      const m = date.getMonth() + 1;
      const d = date.getDate();
      const weekDays = ['周日','周一', '周二', '周三', '周四', '周五', '周六'];
      const w = weekDays[date.getDay()];
      return `${y}年${m}月${d}日 ${w}`;
    }

    function getCurrentData() {
      const key = formatDate(currentDate);
      return database[key] || {};
    }

    function saveData() {
      localStorage.setItem('timeline_daily', JSON.stringify(database));
    }

    function saveCategories() {
      localStorage.setItem('user_categories', JSON.stringify(userCategories));
    }

    function saveSlotsPerHour() {
      localStorage.setItem('slots_per_hour', slotsPerHour.toString());
    }

    function saveUndoHistory() {
      localStorage.setItem('undo_history', JSON.stringify(undoHistory));
    }

    function saveSidebarState() {
      localStorage.setItem('sidebar_collapsed', sidebarCollapsed.toString());
    }

    function loadData() {
      const savedCategories = localStorage.getItem('user_categories');
      if (savedCategories) {
        userCategories = JSON.parse(savedCategories);
      } else {
        userCategories = [...DEFAULT_CATEGORIES];
        saveCategories();
      }

      const savedDatabase = localStorage.getItem('timeline_daily');
      if (savedDatabase) {
        database = JSON.parse(savedDatabase);
      }

      const savedSlots = localStorage.getItem('slots_per_hour');
      if (savedSlots) {
        slotsPerHour = parseInt(savedSlots);
      }

      const savedUndo = localStorage.getItem('undo_history');
      if (savedUndo) {
        undoHistory = JSON.parse(savedUndo);
      }

      const savedSidebarState = localStorage.getItem('sidebar_collapsed');
      if (savedSidebarState === 'true') {
        sidebarCollapsed = true;
        categorySidebar.classList.add('collapsed');
        sidebarToggle.classList.add('collapsed');
      }

      updateUndoButton();
    }

    function generateId() {
      return 'cat_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
    }

    // 折叠/展开侧边栏
    function toggleSidebar() {
      sidebarCollapsed = !sidebarCollapsed;
      if (sidebarCollapsed) {
        categorySidebar.classList.add('collapsed');
        sidebarToggle.classList.add('collapsed');
      } else {
        categorySidebar.classList.remove('collapsed');
        sidebarToggle.classList.remove('collapsed');
      }
      saveSidebarState();
    }

    // 撤销功能
    function pushUndoState() {
      const state = {
        date: formatDate(currentDate),
        data: JSON.parse(JSON.stringify(database))
      };
      undoHistory.push(state);
      if (undoHistory.length > MAX_UNDO_HISTORY) {
        undoHistory.shift();
      }
      saveUndoHistory();
      updateUndoButton();
    }

    function undo() {
      if (undoHistory.length === 0) return;

      const lastState = undoHistory.pop();
      database = lastState.data;
      saveData();
      saveUndoHistory();
      renderTimeline();
      updateStats();
      updateUndoButton();
    }

    function updateUndoButton() {
      if (undoHistory.length > 0) {
        undoBtn.classList.add('active');
      } else {
        undoBtn.classList.remove('active');
      }
    }

    // 渲染分类侧边栏
    function renderCategorySidebar() {
      categorySidebar.innerHTML = '';

      userCategories.forEach(cat => {
        const div = document.createElement('div');
        div.className = `cat-item ${cat.class}`;
        div.dataset.id = cat.id;
        div.dataset.name = cat.name;
        div.dataset.class = cat.class;
        div.textContent = cat.name.slice(0, MAX_NAME_LENGTH);

        // 点击应用分类
        div.addEventListener('click', (e) => {
          e.stopPropagation();
          if (highlightedSlot !== null) {
            applyCategory(cat);
          }
        });

        // 长按事件
        div.addEventListener('touchstart', (e) => {
          e.stopPropagation();
          startLongPress(e, cat);
        }, { passive: false });
        div.addEventListener('touchend', (e) => {
          e.stopPropagation();
          cancelLongPress();
        });
        div.addEventListener('touchmove', cancelLongPress);
        div.addEventListener('mousedown', (e) => startLongPress(e, cat));
        div.addEventListener('mouseup', cancelLongPress);
        div.addEventListener('mouseleave', cancelLongPress);

        categorySidebar.appendChild(div);
      });

      // 添加按钮 - 检查是否达到上限
      const addBtn = document.createElement('div');
      addBtn.className = 'cat-item add-btn';
      if (userCategories.length >= MAX_CATEGORIES) {
        addBtn.classList.add('disabled');
        addBtn.textContent = '满';
        addBtn.style.fontSize = '12px';
      } else {
        addBtn.textContent = '+';
        addBtn.addEventListener('click', openAddModal);
      }
      categorySidebar.appendChild(addBtn);
    }

    function startLongPress(e, cat) {
      longPressTimer = setTimeout(() => {
        longPressedCategory = cat;
        showLongPressMenu(e);
      }, 500);
    }

    function cancelLongPress() {
      if (longPressTimer) {
        clearTimeout(longPressTimer);
        longPressTimer = null;
      }
    }

    function showLongPressMenu(e) {
      let clientX, clientY;
      if (e.touches) {
        clientX = e.touches[0].clientX;
        clientY = e.touches[0].clientY;
      } else {
        clientX = e.clientX;
        clientY = e.clientY;
      }
      longPressMenu.style.top = Math.min(clientY + 10, window.innerHeight - 150) + 'px';
      longPressMenu.style.left = Math.min(clientX - 60, window.innerWidth - 130) + 'px';
      longPressMenu.classList.remove('hidden');
    }

    function hideLongPressMenu() {
      longPressMenu.classList.add('hidden');
      longPressedCategory = null;
    }

    // 渲染时间轴
    function renderTimeline() {
      timelineContainer.innerHTML = '';
      const data = getCurrentData();

      for (let hour = 0; hour < 24; hour++) {
        const row = document.createElement('div');
        row.className = 'time-row';

        const label = document.createElement('div');
        label.className = 'time-label';
        label.textContent = String(hour).padStart(2, '0') + ':00';
        row.appendChild(label);

        const slotsContainer = document.createElement('div');
        slotsContainer.className = 'slots-container';

        for (let slotIndex = 0; slotIndex < slotsPerHour; slotIndex++) {
          const index = hour * slotsPerHour + slotIndex;
          const slot = document.createElement('div');
          slot.className = 'slot';
          slot.dataset.index = index;

          if (data[index]) {
            slot.classList.add(data[index].class);
            slot.textContent = slotsPerHour <= 3 ? data[index].label.slice(0, 2) : '';
          } else {
            slot.classList.add('empty');
          }

          slot.addEventListener('click', (e) => {
            e.stopPropagation();
            selectSlot(index);
          });

          slotsContainer.appendChild(slot);
        }

        row.appendChild(slotsContainer);
        timelineContainer.appendChild(row);
      }

      updateHighlight();
    }

    function selectSlot(index) {
      highlightedSlot = index;
      updateHighlight();
    }

    function updateHighlight() {
      document.querySelectorAll('.slot').forEach(slot => {
        slot.classList.remove('highlight');
        if (parseInt(slot.dataset.index) === highlightedSlot) {
          slot.classList.add('highlight');
        }
      });
    }

    function applyCategory(cat) {
      if (highlightedSlot === null) return;

      // 保存撤销状态
      pushUndoState();

      const key = formatDate(currentDate);
      if (!database[key]) {
        database[key] = {};
      }

      database[key][highlightedSlot] = {
        label: cat.name,
        class: cat.class
      };

      saveData();
      renderTimeline();
      updateStats();
      highlightedSlot = null;
    }

    // 统计页面
    function updateStats() {
      const data = getCurrentData();
      const stats = {};

      userCategories.forEach(cat => {
        stats[cat.id] = { name: cat.name, class: cat.class, count: 0 };
      });

      Object.values(data).forEach(slot => {
        const cat = userCategories.find(c => c.class === slot.class);
        if (cat && stats[cat.id]) {
          stats[cat.id].count++;
        }
      });

      // 更新统计日期
      document.getElementById('statsDate').textContent = formatStatsDate(currentDate);

      // 计算总记录时间和使用的分类数
      const totalSlots = Object.values(data).length;
      const minutesPerSlot = 60 / slotsPerHour;
      const totalMinutes = totalSlots * minutesPerSlot;
      const totalHours = Math.floor(totalMinutes / 60);
      const totalMins = Math.round(totalMinutes % 60);
      const usedCategories = Object.values(stats).filter(s => s.count > 0).length;

      // 更新摘要卡片
      document.getElementById('totalRecorded').textContent = totalHours > 0 ? `${totalHours}h${totalMins}m` : `${totalMins}m`;
      document.getElementById('totalCategories').textContent = usedCategories;

      // 渲染列表
      statsList.innerHTML = '';
      const hasData = Object.values(stats).some(s => s.count > 0);

      if (!hasData) {
        statsList.innerHTML = `
          <div class="no-data">
            <div>今天还没有记录哦</div>
          </div>
        `;
      } else {
        const sortedStats = Object.values(stats).filter(s => s.count > 0).sort((a, b) => b.count - a.count);
        
        sortedStats.forEach(s => {
          const minutes = s.count * minutesPerSlot;
          const hours = Math.floor(minutes / 60);
          const mins = Math.round(minutes % 60);
          const timeStr = hours > 0 ? `${hours}h${mins}m` : `${mins}m`;
          const percent = totalSlots > 0 ? Math.round((s.count / totalSlots) * 100) : 0;

          const item = document.createElement('div');
          item.className = 'stats-item';

          const colorOption = COLOR_OPTIONS.find(c => c.class === s.class);
          const bgColor = colorOption ? colorOption.bg : '#94a3b8';

          item.innerHTML = `
            <div class="stats-color" style="background: ${bgColor}"></div>
            <div class="stats-name">${s.name}</div>
            <div class="stats-time">${timeStr}</div>
            <div class="stats-percent">${percent}%</div>
          `;
          statsList.appendChild(item);
        });
      }

      // 渲染饼图
      renderPieChart(stats);
    }

    function renderPieChart(stats) {
      const ctx = document.getElementById('pieChart').getContext('2d');

      const chartData = Object.values(stats).filter(s => s.count > 0);

      if (pieChart) {
        pieChart.destroy();
      }

      if (chartData.length === 0) {
        return;
      }

      const minutesPerSlot = 60 / slotsPerHour;
      const labels = chartData.map(s => s.name);
      const values = chartData.map(s => s.count * minutesPerSlot);
      const colors = chartData.map(s => {
        const colorOption = COLOR_OPTIONS.find(c => c.class === s.class);
        return colorOption ? colorOption.bg : '#94a3b8';
      });

      pieChart = new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: labels,
          datasets: [{
            data: values,
            backgroundColor: colors,
            borderWidth: 2,
            borderColor: '#ffffff'
          }]
        },
        options: {
          responsive: true,
          cutout: '60%',
          plugins: {
            legend: {
              display: false
            }
          }
        }
      });
    }

    // 日期切换
    function changeDate(offset) {
      currentDate.setDate(currentDate.getDate() + offset);
      currentDateDisplay.innerHTML = formatDateDisplay(currentDate);
      highlightedSlot = null;
      renderTimeline();
      updateStats();
    }

    // 模态框
    function openAddModal() {
      if (userCategories.length >= MAX_CATEGORIES) {
        alert('分类数量已达上限（最多' + MAX_CATEGORIES + '个）');
        return;
      }
      editMode = 'add';
      document.getElementById('modalTitle').textContent = '添加分类';
      document.getElementById('categoryNameInput').value = '';
      selectedColorClass = COLOR_OPTIONS[0].class;
      renderColorOptions();
      editModal.classList.remove('hidden');
    }

    function openEditModal() {
      if (!longPressedCategory) return;
      editMode = 'edit';
      document.getElementById('modalTitle').textContent = '编辑分类';
      document.getElementById('categoryNameInput').value = longPressedCategory.name;
      selectedColorClass = longPressedCategory.class;
      renderColorOptions();
      editModal.classList.remove('hidden');
      hideLongPressMenu();
    }

    function renderColorOptions() {
      const container = document.getElementById('colorOptions');
      container.innerHTML = '';

      COLOR_OPTIONS.forEach(color => {
        const div = document.createElement('div');
        div.className = `color-option ${color.class}`;
        if (color.class === selectedColorClass) {
          div.classList.add('selected');
        }
        div.addEventListener('click', () => {
          selectedColorClass = color.class;
          renderColorOptions();
        });
        container.appendChild(div);
      });
    }

    // 保存分类（添加或编辑）
    function saveCategory() {
      let name = document.getElementById('categoryNameInput').value.trim();
      if (!name) {
        alert('请输入分类名称');
        return;
      }

      // 限制名称长度为4个字符
      if (name.length > MAX_NAME_LENGTH) {
        name = name.slice(0, MAX_NAME_LENGTH);
      }

      if (editMode === 'add') {
        const newCat = {
          id: generateId(),
          name: name,
          class: selectedColorClass
        };
        userCategories.push(newCat);
      } else {
        const index = userCategories.findIndex(c => c.id === longPressedCategory.id);
        if (index !== -1) {
          userCategories[index].name = name;
          userCategories[index].class = selectedColorClass;
        }
      }

      saveCategories();
      renderCategorySidebar();
      renderTimeline();
      updateStats();
      editModal.classList.add('hidden');
    }

    // 删除分类
    function deleteCategory() {
      if (!longPressedCategory) return;
      const index = userCategories.findIndex(c => c.id === longPressedCategory.id);
      if (index !== -1) {
        userCategories.splice(index, 1);
        saveCategories();
        renderCategorySidebar();
        updateStats();
      }
      hideLongPressMenu();
    }

    // 清空今日数据
    function clearToday() {
      if (confirm('确定清空今日所有时间块吗？')) {
        // 保存撤销状态
        pushUndoState();

        const key = formatDate(currentDate);
        database[key] = {};
        saveData();
        renderTimeline();
        updateStats();
        highlightedSlot = null;
        hideDropdownMenu();
      }
    }

    // 下拉菜单
    function toggleDropdownMenu() {
      dropdownMenu.classList.toggle('hidden');
    }

    function hideDropdownMenu() {
      dropdownMenu.classList.add('hidden');
    }

    function updateBlockSizeButtons() {
      document.querySelectorAll('.block-size-btn').forEach(btn => {
        btn.classList.remove('active');
        if (parseInt(btn.dataset.size) === slotsPerHour) {
          btn.classList.add('active');
        }
      });
    }

    function setBlockSize(size) {
      slotsPerHour = size;
      saveSlotsPerHour();
      updateBlockSizeButtons();
      renderTimeline();
      updateStats();
    }

    // 首次提示
    function showGuideIfNeeded() {
      const shown = localStorage.getItem('guide_shown');
      if (!shown) {
        guideTip.classList.remove('hidden');
        setTimeout(() => {
          guideTip.classList.add('hidden');
          localStorage.setItem('guide_shown', '1');
        }, 5000);
        guideTip.addEventListener('click', () => {
          guideTip.classList.add('hidden');
          localStorage.setItem('guide_shown', '1');
        });
      }
    }

    // 切换页面
    function showPage(page) {
      timelinePage.classList.add('hidden');
      statsPage.classList.add('hidden');
      aboutPage.classList.add('hidden');
      tabTimeline.classList.remove('active');
      tabStats.classList.remove('active');
      tabAbout.classList.remove('active');

      if (page === 'timeline') {
        timelinePage.classList.remove('hidden');
        tabTimeline.classList.add('active');
      } else if (page === 'stats') {
        statsPage.classList.remove('hidden');
        tabStats.classList.add('active');
        updateStats();
      } else if (page === 'about') {
        aboutPage.classList.remove('hidden');
        tabAbout.classList.add('active');
      }
    }

    // 初始化
    function init() {
      loadData();
      currentDateDisplay.innerHTML = formatDateDisplay(currentDate);
      updateBlockSizeButtons();
      renderCategorySidebar();
      renderTimeline();
      updateStats();
      showGuideIfNeeded();

      // 事件绑定
      document.getElementById('prevDay').addEventListener('click', () => changeDate(-1));
      document.getElementById('nextDay').addEventListener('click', () => changeDate(1));

      // 撤销按钮
      undoBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        undo();
      });

      // 侧边栏折叠按钮
      sidebarToggle.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleSidebar();
      });

      // 菜单切换
      document.getElementById('menuToggle').addEventListener('click', (e) => {
        e.stopPropagation();
        toggleDropdownMenu();
      });

      // 清空今日
      document.getElementById('clearTodayBtn').addEventListener('click', clearToday);

      // 块大小选择
      document.querySelectorAll('.block-size-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          setBlockSize(parseInt(btn.dataset.size));
        });
      });

      // Tab切换
      tabTimeline.addEventListener('click', () => showPage('timeline'));
      tabStats.addEventListener('click', () => showPage('stats'));
      tabAbout.addEventListener('click', () => showPage('about'));

      // 长按菜单按钮
      document.getElementById('menuEdit').addEventListener('click', () => {
        if (longPressedCategory) {
          openEditModal();
        }
      });
      document.getElementById('menuDelete').addEventListener('click', () => {
        deleteCategory();
      });
      document.getElementById('menuCancel').addEventListener('click', hideLongPressMenu);

      // 点击外部关闭菜单
      document.addEventListener('click', (e) => {
        if (!longPressMenu.contains(e.target)) {
          hideLongPressMenu();
        }
        if (!dropdownMenu.contains(e.target) && e.target.id !== 'menuToggle' && !e.target.closest('#menuToggle')) {
          hideDropdownMenu();
        }
      });

      // 模态框按钮
      document.getElementById('modalCancel').addEventListener('click', () => {
        editModal.classList.add('hidden');
      });
      document.getElementById('modalSave').addEventListener('click', saveCategory);

      // 点击空白取消高亮
      document.addEventListener('click', (e) => {
        if (!e.target.closest('.slot') && !e.target.closest('.cat-item')) {
          highlightedSlot = null;
          updateHighlight();
        }
      });

      // 输入框限制字符数
      document.getElementById('categoryNameInput').addEventListener('input', (e) => {
        if (e.target.value.length > MAX_NAME_LENGTH) {
          e.target.value = e.target.value.slice(0, MAX_NAME_LENGTH);
        }
      });
    }

    init();
  </script>
</body>
</html>
